  <div class="dock-item" onclick="openWindow('win-capstone')">
    <div class="dock-icon">📁</div>
    <div class="dock-label">Capstone</div>
  </div>
  <div class="dock-item" onclick="openWindow('win-stress')">
    <div class="dock-icon">🧠</div>
    <div class="dock-label">EEG Sim</div>
  </div>
  <div class="dock-item" onclick="openWindow('win-notebook')">
    <div class="dock-icon">🎙️</div>
    <div class="dock-label">NotebookLM</div>
