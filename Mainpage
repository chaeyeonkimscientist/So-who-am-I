<script>
// ── CLOCK ──
function updateClock() {
  const now = new Date();
  document.getElementById('clock').textContent =
    now.toLocaleTimeString('en-US', {hour:'2-digit', minute:'2-digit'});
}
updateClock();
setInterval(updateClock, 1000);

// ── WINDOW MANAGEMENT ──
let activeWindow = null;

function openWindow(id) {
  const win = document.getElementById(id);
  if (!win) return;

  // Deactivate all
  document.querySelectorAll('.window').forEach(w => w.classList.remove('active'));

  // Position if first open
  if (!win.classList.contains('visible')) {
    const offset = Math.random() * 30 - 15;
    win.style.left = (80 + offset) + 'px';
    win.style.top  = (60 + offset) + 'px';
    win.classList.add('visible');
  }

  win.classList.add('active');
  activeWindow = id;

  if (id === 'win-stress') initEEGCanvas();
}

function closeWindow(id) {
  const win = document.getElementById(id);
  win.classList.remove('visible', 'active');
}

// Click window to activate
document.querySelectorAll('.window').forEach(win => {
  win.addEventListener('mousedown', () => {
    document.querySelectorAll('.window').forEach(w => w.classList.remove('active'));
    win.classList.add('active');
  });
});

// ── DRAG ──
let dragging = null, dragOffX = 0, dragOffY = 0;

function startDrag(e, id) {
  const win = document.getElementById(id);
  dragging = win;
  dragOffX = e.clientX - win.offsetLeft;
  dragOffY = e.clientY - win.offsetTop;
  e.preventDefault();
}

document.addEventListener('mousemove', e => {
  if (!dragging) return;
  dragging.style.left = (e.clientX - dragOffX) + 'px';
  dragging.style.top  = Math.max(22, e.clientY - dragOffY) + 'px';
});

document.addEventListener('mouseup', () => { dragging = null; });

// ── EEG CANVAS ──
let eegCanvas, eegCtx, eegAnim;
let stressLevel = 0.15;
let targetStress = 0.15;
let waveOffset = 0;
let stressMode = 'baseline';

const stressModes = [
  { name: 'CapBaseline', stress: 0.15, label: 'BASELINE', color: '#4a90d9', desc: 'α power: high · HPA axis: inactive', reading: 'α suppression: 12% · System at rest' },
  { name: 'CapNback', stress: 0.65, label: 'COGNITIVE STRESS', color: '#f0a500', desc: 'α suppression: active · DLPFC engaged', reading: 'α suppression: 63% · HPA axis: activating' },
  { name: 'CapLinkedin', stress: 0.75, label: 'SOCIAL THREAT', color: '#e74c3c', desc: 'amygdala → SNS → cytokine cascade', reading: 'α suppression: 78% · immune response: elevated' },
  { name: 'CapRecovery', stress: 0.28, label: 'RECOVERY', color: '#27ae60', desc: 'α power: returning · HPA axis: dampening', reading: 'α suppression: 28% · partial recovery' },
];
let modeIndex = 0;

function initEEGCanvas() {
  eegCanvas = document.getElementById('eeg-canvas');
  if (!eegCanvas) return;
  eegCtx = eegCanvas.getContext('2d');
  resizeCanvas();
  if (!eegAnim) animateEEG();
}

function resizeCanvas() {
  if (!eegCanvas) return;
  const container = document.getElementById('stress-container');
  eegCanvas.width = container.offsetWidth;
  eegCanvas.height = container.offsetHeight;
}

function animateEEG() {
  eegAnim = requestAnimationFrame(animateEEG);
  if (!eegCtx) return;

  const w = eegCanvas.width, h = eegCanvas.height;
  const mode = stressModes[modeIndex];

  // Smooth stress
  stressLevel += (targetStress - stressLevel) * 0.04;

  // Background
  const bgIntensity = Math.floor(stressLevel * 20);
  eegCtx.fillStyle = `rgb(${bgIntensity},${Math.floor(bgIntensity*0.3)},${Math.floor(bgIntensity*0.3)})`;
  eegCtx.fillRect(0, 0, w, h);

  // Draw EEG waves
  const numWaves = 3;
  for (let wi = 0; wi < numWaves; wi++) {
    eegCtx.beginPath();
    const amplitude = 15 + stressLevel * 60 + wi * 8;
    const freq = 0.02 + stressLevel * 0.04 + wi * 0.008;
    const yBase = h * (0.3 + wi * 0.2);
    const speed = 2 + stressLevel * 4;
    const alpha = 0.15 + (numWaves - wi) * 0.12;

    // Color interpolation
    const r = Math.floor(74 + stressLevel * 118);
    const g = Math.floor(144 - stressLevel * 100);
    const b = Math.floor(217 - stressLevel * 170);
    eegCtx.strokeStyle = `rgba(${r},${g},${b},${alpha})`;
    eegCtx.lineWidth = 1.5 - wi * 0.3;

    for (let x = 0; x < w; x++) {
      const noise = (Math.random() - 0.5) * stressLevel * 12;
      const y = yBase
        + Math.sin((x * freq) + waveOffset * speed + wi * 2) * amplitude
        + Math.sin((x * freq * 2.3) + waveOffset * speed * 0.7 + wi) * amplitude * 0.4
        + noise;
      x === 0 ? eegCtx.moveTo(x, y) : eegCtx.lineTo(x, y);
    }
    eegCtx.stroke();
  }

  // Main bright wave
  eegCtx.beginPath();
  const mainAmplitude = 20 + stressLevel * 80;
  const r = Math.floor(74 + stressLevel * 118);
  const g = Math.floor(144 - stressLevel * 100);
  const b = Math.floor(217 - stressLevel * 170);
  eegCtx.strokeStyle = `rgba(${r},${g},${b},0.9)`;
  eegCtx.lineWidth = 2;

  for (let x = 0; x < w; x++) {
    const spike = stressLevel > 0.5 && Math.random() < 0.003 ? (Math.random() - 0.5) * 80 : 0;
    const y = h * 0.5
      + Math.sin((x * 0.025) + waveOffset * (2 + stressLevel * 3)) * mainAmplitude
      + Math.sin((x * 0.051) + waveOffset * 1.4) * mainAmplitude * 0.5
      + spike;
    x === 0 ? eegCtx.moveTo(x, y) : eegCtx.lineTo(x, y);
  }
  eegCtx.stroke();

  // Grid lines
  eegCtx.strokeStyle = 'rgba(255,255,255,0.05)';
  eegCtx.lineWidth = 1;
  for (let x = 0; x < w; x += 40) {
    eegCtx.beginPath();
    eegCtx.moveTo(x, 0);
    eegCtx.lineTo(x, h);
    eegCtx.stroke();
  }

  waveOffset += 0.015;

  // Update UI
  document.getElementById('stress-bar').style.width = (stressLevel * 100) + '%';
  document.getElementById('stress-container').style.background =
    `rgb(${Math.floor(stressLevel * 25)},${Math.floor(stressLevel * 8)},${Math.floor(stressLevel * 8)})`;
}

function runStressSimulation() {
  modeIndex = (modeIndex + 1) % stressModes.length;
  const mode = stressModes[modeIndex];
  targetStress = mode.stress;

  document.getElementById('stress-label').textContent = mode.label;
  document.getElementById('stress-label').style.color = mode.color;
  document.getElementById('stress-label').style.textShadow = `0 0 30px ${mode.color}`;
  document.getElementById('stress-desc').innerHTML =
    mode.desc + '<br><span id="eeg-reading" style="color:' + mode.color + '">' + mode.reading + '</span>';
  document.getElementById('stress-mode-label').textContent =
    'Simulating: ' + mode.name + ' · Chaeyeon\'s actual EEG segment';

  const labels = ['▶ Induce Stress Condition', '▶ Social Threat (LinkedIn)', '▶ Brief Recovery', '▶ Reset to Baseline'];
  document.getElementById('stress-btn').textContent = labels[modeIndex];
}

// ── AUDIO SIMULATION ──
let audioPlaying = false, audioInterval;

function simulatePlay() {
  if (audioPlaying) {
    clearInterval(audioInterval);
    audioPlaying = false;
    document.querySelector('.play-btn').textContent = '▶';
    return;
  }
  audioPlaying = true;
  document.querySelector('.play-btn').textContent = '⏸';
  let progress = 0;
  audioInterval = setInterval(() => {
    progress += 0.7;
    document.getElementById('audio-bar').style.width = Math.min(progress, 100) + '%';
    if (progress >= 100) {
      clearInterval(audioInterval);
      audioPlaying = false;
      document.querySelector('.play-btn').textContent = '▶';
      document.getElementById('audio-status').textContent = '→ Replace with your NotebookLM audio embed';
    }
  }, 900);
}

// Open README on load
window.onload = () => {
  setTimeout(() => openWindow('win-about'), 300);
};
</script>
</body>
